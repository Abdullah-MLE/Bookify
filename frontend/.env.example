# Backend API URLs
NEXT_PUBLIC_TWIN_API_URL=https://your-twin-lambda-url.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_URL=https://your-ecs-backend-url.on.aws/api
