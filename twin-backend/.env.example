# Gemini via Vertex AI (Service Account)
GCP_LOCATION=us-central1
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/gcp-key.json

# OR: paste the entire JSON as a single line (for Cloud Function / Lambda)
# GCP_KEY_JSON={"type":"service_account","project_id":"..."}

# CORS
CORS_ORIGINS=http://localhost:3000
